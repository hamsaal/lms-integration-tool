#!/usr/bin/env bash
set -euo pipefail

export RAILS_ENV=test
export DATABASE_URL=postgres://postgres:postgres@postgres:5432/learning_integrations_test
export TEST_DATABASE_URL=postgres://postgres:postgres@postgres:5432/learning_integrations_test
export REDIS_URL=redis://redis:6379/0
export JWT_SECRET=development-only-secret
export FRONTEND_ORIGIN=http://localhost:5173,http://frontend:5173
export VITE_API_BASE_URL=http://api:3000

docker compose up -d postgres redis
docker compose stop api sidekiq frontend >/dev/null 2>&1 || true
docker compose build api

docker compose run --rm \
  -e RAILS_ENV \
  -e DATABASE_URL \
  -e TEST_DATABASE_URL \
  -e REDIS_URL \
  -e JWT_SECRET \
  api bash -lc "bundle exec rails db:drop || true; bundle exec rails db:prepare; bundle exec rails db:seed"

docker compose up -d --force-recreate api frontend
docker compose run --rm e2e

echo "End-to-end launch flow passed."
